{
    Serial.println("\n========================================");
    Serial.print("BLINK raw   : "); Serial.print(basira.blink.analog);
    Serial.print("  eye=");
    Serial.print(basira.blink.eye == EYE_CLOSED ? "CLOSED" : "OPEN");
    Serial.print("  count="); Serial.println(basira.blink.blinkCount);
    Serial.print("BLINK rate  : ");
    if (basira.blink.windowReady)
        { Serial.print(basira.blink.blinkRate, 1); Serial.println(" /min"); }
    else
        Serial.println("(30s window not ready)");
    Serial.print("PERCLOS     : "); Serial.print(basira.blink.perclos, 1); Serial.println(" %");

    Serial.print("GSR raw     : "); Serial.println(basira.gsr.raw);
    Serial.print("  on-skin=");
    Serial.println(basira.gsr.onSkin ? "YES" : "NO — attach both electrodes to skin");
    Serial.print("GSR filtered: "); Serial.println(basira.gsr.filtered, 1);
    Serial.print("GSR delta   : "); Serial.println(basira.gsr.delta, 1);

    Serial.print("Heart Rate  : ");
    if (basira.heart.skin == ON_SKIN)
        { Serial.print(basira.heart.averageBPM, 1); Serial.println(" BPM"); }
    else
        Serial.println("(off-skin)");
    Serial.print("HRV         : ");
    if (rrSamples >= 5)
        { Serial.print(basira.heart.hrv, 1); Serial.println(" ms"); }
    else
        { Serial.print("(need "); Serial.print(5 - rrSamples); Serial.println(" more beats)"); }

    Serial.print("Light diff  : "); Serial.print(basira.light.lastDiff);
    Serial.print("  state=");
    switch (basira.light.state) {
        case LIGHT_DARK:   Serial.println("DARK");   break;
        case LIGHT_BRIGHT: Serial.println("BRIGHT"); break;
        case LIGHT_NORMAL: Serial.println("NORMAL"); break;
        default:           Serial.println("UNKNOWN");
    }
    Serial.print("Risk score  : "); Serial.println(basira.decision.riskScore);
    Serial.print("System state: ");
    switch (basira.decision.state) {
        case SYSTEM_HEALTHY:        Serial.println("HEALTHY");        break;
        case SYSTEM_MILD_FATIGUE:   Serial.println("MILD_FATIGUE");   break;
        case SYSTEM_VISUAL_FATIGUE: Serial.println("VISUAL_FATIGUE"); break;
        case SYSTEM_HIGH_STRESS:    Serial.println("HIGH_STRESS");    break;
        case SYSTEM_MONITORING:     Serial.println("MONITORING");     break;
        default:                    Serial.println("STARTUP/CALIB");  break;
    }
    Serial.print("BLE         : "); Serial.println(bleConnected ? "CONNECTED" : "NOT CONNECTED");
    Serial.println("========================================");
}

// ============================================================
//  Setup
// ============================================================
void setup()
{
    Serial.begin(115200);
    delay(1000);
    Serial.println("========================================");
    Serial.println(" BASIRA Smart Glasses  Firmware v3.3.0");
    Serial.println("========================================");
    Serial.println(" IMPORTANT: Before calibration starts,");
    Serial.println(" place BOTH GSR electrodes on skin.");
    Serial.println(" Calibration lasts 5 seconds.");
    Serial.println("========================================");

    initializeHardware();
    initializeBLE();

    calibrationStart      = millis();
    basira.decision.state = SYSTEM_CALIBRATION;
    timerBleNotify        = 0;

    Serial.println("Calibrating — keep still for 5 seconds...");
}

// ============================================================
//  Loop
// ============================================================
void loop()
{
    if (!calibrationFinished)
    {
        runCalibration();
        return;
    }

    uint32_t now = millis();

    if (taskReady(now, timerHeart,    HEART_PERIOD))   readHeartSensor();
    if (taskReady(now, timerBlink,    BLINK_PERIOD))   readBlinkSensor();   // FIX-1: edge detection here
    if (taskReady(now, timerGSR,      GSR_PERIOD))     readGSRSensor();
    if (taskReady(now, timerLight,    LIGHT_PERIOD))   readLightSensor();
    if (taskReady(now, timerFeature,  FEATURE_PERIOD)) extractFeatures();   // rate calc only
    if (taskReady(now, timerDecision, DECISION_PERIOD))
    {
        evaluatePhysiology();
        updateDecisionEngine();
    }
    if (taskReady(now, timerBleNotify, BLE_NOTIFY_PERIOD))
    {
        sendBlePacket();
        printDebug();
    }

    updateMotor();
}
