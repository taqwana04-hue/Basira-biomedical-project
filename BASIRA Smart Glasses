// ============================================================
//  Pin map
// ============================================================
const uint8_t PIN_BLINK_AO = 0;
const uint8_t PIN_GSR      = 4;
const uint8_t PIN_LDR      = 3;
const uint8_t PIN_SDA      = 8;
const uint8_t PIN_SCL      = 9;
const uint8_t PIN_MOTOR    = 10;

// ============================================================
//  Scheduler periods (ms)
// ============================================================
const uint16_t HEART_PERIOD      = 20;
const uint16_t BLINK_PERIOD      = 20;
const uint16_t GSR_PERIOD        = 200;
const uint16_t LIGHT_PERIOD      = 500;
const uint16_t FEATURE_PERIOD    = 1000;
const uint16_t DECISION_PERIOD   = 2000;
const uint16_t BLE_NOTIFY_PERIOD = 1000;

// ============================================================
//  ADC averaging sample counts
// ============================================================
const uint8_t TCRT_SAMPLES = 8;
const uint8_t GSR_SAMPLES  = 10;

// ============================================================
//  Blink hysteresis thresholds — 12-bit / ADC_11db (0–3.3V)
//
//  VERIFIED from serial log:
//    Eye OPEN  → BLINK raw = 4095
//    Eye CLOSED → BLINK raw = 297–343
//  These thresholds are correct and must NOT be changed.
// ============================================================
const uint16_t BLINK_OPEN_THRESHOLD   = 2200;
const uint16_t BLINK_CLOSED_THRESHOLD = 1700;

// ============================================================
//  PERCLOS window
// ============================================================
const uint32_t PERCLOS_WINDOW_MS = 60000UL;

// ============================================================
//  Physiological thresholds
// ============================================================
const long     IR_ON_SKIN_THRESHOLD  = 10000;
const uint16_t RR_MIN_MS             = 300;
const uint16_t RR_MAX_MS             = 1500;
const uint16_t CALIBRATION_TIME_MS   = 5000;

const float  THRESHOLD_HRV_LOW       = 20.0f;
const float  THRESHOLD_HEART_HIGH    = 100.0f;

// Light thresholds (restored from v3.0)
const int    THRESHOLD_LIGHT_DARK    = -120;
const int    THRESHOLD_LIGHT_BRIGHT  = 250;
const int    THRESHOLD_LIGHT_HYST    = 10;

const int    THRESHOLD_GSR_ELEVATED  = -20;

// FIX-2: 3800 is more conservative than 3900.
// Grove GSR with skin contact: ~1000–3000 ADC (12-bit, ADC_11db).
// Grove GSR no skin / floating: 3900–4095.
// 3800 gives a clear safety margin.
const uint16_t GSR_FLOATING_THRESHOLD = 3800;

const float PERCLOS_MILD   = 20.0f;
const float PERCLOS_SEVERE = 40.0f;

// ============================================================
//  Enumerations
// ============================================================
enum EyeState    { EYE_UNKNOWN, EYE_OPEN, EYE_CLOSED };
enum LightState  { LIGHT_UNKNOWN, LIGHT_DARK, LIGHT_NORMAL, LIGHT_BRIGHT };
enum SkinState   { OFF_SKIN, ON_SKIN };
enum SystemState { SYSTEM_STARTUP, SYSTEM_CALIBRATION, SYSTEM_MONITORING,
                   SYSTEM_HEALTHY, SYSTEM_MILD_FATIGUE,
                   SYSTEM_VISUAL_FATIGUE, SYSTEM_HIGH_STRESS };
enum BlinkStatus { BLINK_UNKNOWN, BLINK_NORMAL, BLINK_LOW, BLINK_VERY_LOW };
enum HeartStatus { HEART_UNKNOWN, HEART_NORMAL, HEART_HIGH };
enum HRVStatus   { HRV_UNKNOWN, HRV_NORMAL, HRV_LOW };
enum GSRStatus   { GSR_UNKNOWN, GSR_NORMAL, GSR_ELEVATED };

// ============================================================
//  Structs
// ============================================================
struct BlinkSensor
{
    uint16_t analog;
    EyeState eye;
    uint32_t blinkCount;      // FIX-1: incremented in readBlinkSensor() at 20ms
    float    blinkRate;
    uint16_t eyeClosureTime;
    bool     windowReady;

    uint32_t closedMsInWindow;
    uint32_t percloseWindowStart;
    float    perclos;
};

struct HeartSensor
{
    long      ir;
    SkinState skin;
    bool      beatDetected;
    float     bpm;
    float     averageBPM;
    uint16_t  rr;
    float     hrv;
};

struct GSRSensor
{
    uint16_t raw;
    float    filtered;
    float    baseline;
    float    delta;
    bool     onSkin;
};

struct LightSensor
{
    uint16_t   raw;
    uint16_t   baseline;
    LightState state;
    int        lastDiff;
};

struct PhysiologicalState
{
    BlinkStatus blink;
    HeartStatus heart;
    HRVStatus   hrv;
    GSRStatus   gsr;
};

struct DecisionEngine
{
    uint8_t     riskScore;
    SystemState state;
    bool        vibration;
};

struct BasiraSystem
{
    BlinkSensor        blink;
    HeartSensor        heart;
    GSRSensor          gsr;
    LightSensor        light;
    PhysiologicalState physiology;
    DecisionEngine     decision;
};

// ============================================================
//  Globals
// ============================================================
BasiraSystem basira;
MAX30105     max30102;

uint32_t timerBlink     = 0;
uint32_t timerHeart     = 0;
uint32_t timerGSR       = 0;
uint32_t timerLight     = 0;
uint32_t timerFeature   = 0;
uint32_t timerDecision  = 0;
uint32_t timerBleNotify = 0;   // 0 → first packet fires immediately after calibration

bool     calibrationFinished = false;
uint32_t calibrationStart    = 0;

// FIX-1: blink edge state lives here, updated at 20ms in readBlinkSensor()
EyeState previousEyeState   = EYE_UNKNOWN;
uint32_t eyeClosedStart      = 0;
uint32_t blinkWindowStart    = 0;
uint32_t lastPerclosTickMs   = 0;

bool     motorRunning   = false;
uint32_t motorStartTime = 0;
const uint16_t MOTOR_PULSE_MS = 300;

// HRV ring buffer
const uint8_t RR_BUF = 20;
uint16_t rrHistory[RR_BUF];
uint8_t  rrIndex   = 0;
uint8_t  rrSamples = 0;

// BLE
BLEServer*         bleServer   = nullptr;
BLECharacteristic* bleDataChar = nullptr;
bool               bleConnected = false;
uint32_t           packetSeq   = 0;

// ============================================================
//  ADC averaging helper
//  500µs between samples: gives SAR capacitor time to charge
// ============================================================
uint16_t adcAverage(uint8_t pin, uint8_t n)
{
    uint32_t sum = 0;
    for (uint8_t i = 0; i < n; i++)
    {
        sum += analogRead(pin);
        delayMicroseconds(500);
    }
    return (uint16_t)(sum / n);
}

// ============================================================
//  BLE server callbacks
// ============================================================
class BasiraServerCallbacks : public BLEServerCallbacks
{
    void onConnect(BLEServer*) override
    {
        bleConnected = true;
        Serial.println("[BLE] Central connected");
    }
    void onDisconnect(BLEServer* server) override
    {
        bleConnected = false;
        Serial.println("[BLE] Central disconnected — resuming advertising");
        delay(200);
        server->getAdvertising()->start();
    }
};

// ============================================================
//  Scheduler helper
// ============================================================
inline bool taskReady(uint32_t now, uint32_t &last, uint32_t period)
{
    if (now - last >= period) { last = now; return true; }
    return false;
}

// ============================================================
//  Hardware init
// ============================================================
void initializeVariables()
{
    memset(&basira, 0, sizeof(BasiraSystem));
    basira.blink.eye              = EYE_UNKNOWN;
    basira.blink.windowReady      = false;
    basira.blink.perclos          = 0.0f;
    basira.light.state            = LIGHT_UNKNOWN;
    basira.light.lastDiff         = 0;
    basira.heart.skin             = OFF_SKIN;
    basira.gsr.onSkin             = false;
    basira.decision.state         = SYSTEM_STARTUP;
    basira.physiology.blink       = BLINK_UNKNOWN;
    basira.physiology.heart       = HEART_UNKNOWN;
    basira.physiology.hrv         = HRV_UNKNOWN;
    basira.physiology.gsr         = GSR_UNKNOWN;
}

void initMAX30102()
{
    if (!max30102.begin(Wire))
    {
        Serial.println("ERROR: MAX30102 NOT FOUND — halting");
        while (true) delay(1000);
    }
    max30102.setup();
    max30102.setPulseAmplitudeRed(0x0A);
    max30102.setPulseAmplitudeIR(0x1F);
    Serial.println("MAX30102 OK");
}

void initializeHardware()
{
    pinMode(PIN_MOTOR, OUTPUT);
    digitalWrite(PIN_MOTOR, LOW);

    // 12-bit ADC, full 0–3.3V range for all analog pins
    analogReadResolution(12);
    analogSetAttenuation(ADC_11db);

    // FIX-2: explicit per-pin attenuation for GPIO2 (strapping pin)
    // Some ESP32-C3 Arduino core versions require this explicitly
    analogSetPinAttenuation(PIN_GSR,      ADC_11db);
    analogSetPinAttenuation(PIN_BLINK_AO, ADC_11db);
    analogSetPinAttenuation(PIN_LDR,      ADC_11db);

    Wire.begin(PIN_SDA, PIN_SCL);
    initMAX30102();
    initializeVariables();
}

// ============================================================
//  BLE init
// ============================================================
void initializeBLE()
{
    BLEDevice::init(BASIRA_DEVICE_NAME);
    bleServer = BLEDevice::createServer();
    bleServer->setCallbacks(new BasiraServerCallbacks());

    BLEService* svc = bleServer->createService(BASIRA_SERVICE_UUID);
    bleDataChar = svc->createCharacteristic(
        BASIRA_CHAR_DATA_UUID,
        BLECharacteristic::PROPERTY_NOTIFY
    );
    bleDataChar->addDescriptor(new BLE2902());
    svc->start();

    BLEAdvertising* adv = BLEDevice::getAdvertising();
    adv->addServiceUUID(BASIRA_SERVICE_UUID);
    adv->setScanResponse(true);
    adv->setMinPreferred(0x00);
    BLEDevice::startAdvertising();

    Serial.println("[BLE] Advertising as '" BASIRA_DEVICE_NAME "'");
}

// ============================================================
//  Calibration
// ============================================================
void runCalibration()
{
    static uint32_t samples  = 0;
    static uint64_t gsrSum   = 0;
    static uint64_t lightSum = 0;

    gsrSum   += adcAverage(PIN_GSR, GSR_SAMPLES);
    lightSum += analogRead(PIN_LDR);
    samples++;

    if (millis() - calibrationStart >= CALIBRATION_TIME_MS)
    {
        basira.gsr.baseline   = (float)gsrSum   / samples;
        basira.light.baseline = (uint16_t)(lightSum / samples);
        basira.gsr.onSkin     = (basira.gsr.baseline < GSR_FLOATING_THRESHOLD);
        basira.gsr.filtered   = basira.gsr.baseline;

        calibrationFinished       = true;
        basira.decision.state     = SYSTEM_MONITORING;

        uint32_t now = millis();
        blinkWindowStart                 = now;
        basira.blink.percloseWindowStart = now;
        lastPerclosTickMs                = now;

        Serial.println("\n=== Calibration Complete ===");
        Serial.print("  GSR baseline   : "); Serial.println(basira.gsr.baseline);
        Serial.print("  GSR on-skin    : ");
        if (basira.gsr.onSkin)
            Serial.println("YES — electrodes detected");
        else
            Serial.println("NO — place BOTH electrodes on index+middle finger then restart");
        Serial.print("  Light baseline : "); Serial.println(basira.light.baseline);
        Serial.println("  Blink thresholds (verified 12-bit ADC_11db):");
        Serial.print("    OPEN=");   Serial.print(BLINK_OPEN_THRESHOLD);
        Serial.print("  CLOSED="); Serial.println(BLINK_CLOSED_THRESHOLD);
        Serial.println("============================\n");
    }
}

// ============================================================
//  Sensor: Blink
//
//  FIX-1: Edge detection (blinkCount++) moved here from
//  calculateBlinkFeatures(). This function runs every 20ms —
//  fast enough to catch any blink ≥40ms duration.
//
//  PERCLOS accumulation also here (unchanged from v3.2).
// ============================================================
void readBlinkSensor()
{
    basira.blink.analog = adcAverage(PIN_BLINK_AO, TCRT_SAMPLES);
    uint16_t val = basira.blink.analog;

    // Hysteresis state machine
    EyeState newState = basira.blink.eye;
    if (basira.blink.eye != EYE_CLOSED && val < BLINK_CLOSED_THRESHOLD)
        newState = EYE_CLOSED;
    else if (basira.blink.eye != EYE_OPEN && val > BLINK_OPEN_THRESHOLD)
        newState = EYE_OPEN;
    // [1700..2200]: hold current state — hysteresis dead-band

    if (newState == EYE_UNKNOWN) newState = EYE_OPEN;
    basira.blink.eye = newState;

    // ── FIX-1: BLINK EDGE DETECTION at 20ms resolution ──────
    bool isClosed  = (basira.blink.eye == EYE_CLOSED);
    bool wasClosed = (previousEyeState == EYE_CLOSED);

    // Eye just closed (OPEN → CLOSED transition)
    if (isClosed && !wasClosed)
    {
        eyeClosedStart = millis();
    }

    // Eye just opened (CLOSED → OPEN transition) → one blink completed
    if (!isClosed && wasClosed)
    {
        uint32_t dur = millis() - eyeClosedStart;
        // Accept blinks between 50ms (physiological minimum) and 800ms
        if (dur >= 50 && dur <= 800)
        {
            basira.blink.eyeClosureTime = (uint16_t)dur;
            basira.blink.blinkCount++;   // ← this was missing at 20ms resolution
        }
    }

    previousEyeState = basira.blink.eye;
    // ─────────────────────────────────────────────────────────

    // PERCLOS accumulation: add real elapsed ms when eye is closed
    uint32_t now = millis();
    if (basira.blink.eye == EYE_CLOSED)
    {
        uint32_t elapsed = now - lastPerclosTickMs;
        if (elapsed < BLINK_PERIOD * 4)
            basira.blink.closedMsInWindow += elapsed;
    }
    lastPerclosTickMs = now;
}

// ============================================================
//  Sensor: GSR
// ============================================================
void readGSRSensor()
{
    const float alpha = 0.20f;
    basira.gsr.raw    = adcAverage(PIN_GSR, GSR_SAMPLES);
    basira.gsr.onSkin = (basira.gsr.raw < GSR_FLOATING_THRESHOLD);
    basira.gsr.filtered = alpha * basira.gsr.raw + (1.0f - alpha) * basira.gsr.filtered;

    if (basira.gsr.onSkin)
        basira.gsr.delta = basira.gsr.filtered - basira.gsr.baseline;
    else
        basira.gsr.delta = 0.0f;
}

// ============================================================
//  Sensor: Light — FIX-3: restored v3.0 behavior with hysteresis
// ============================================================
void readLightSensor()
{
    basira.light.raw = adcAverage(PIN_LDR, 8);
    int diff = (int)basira.light.raw - (int)basira.light.baseline;

    LightState current = basira.light.state;
    LightState next    = current;

    if (current == LIGHT_DARK)
    {
        if (diff > THRESHOLD_LIGHT_DARK + THRESHOLD_LIGHT_HYST)   next = LIGHT_NORMAL;
    }
    else if (current == LIGHT_BRIGHT)
    {
        if (diff < THRESHOLD_LIGHT_BRIGHT - THRESHOLD_LIGHT_HYST) next = LIGHT_NORMAL;
    }
    else
    {
        if      (diff < THRESHOLD_LIGHT_DARK   - THRESHOLD_LIGHT_HYST) next = LIGHT_DARK;
        else if (diff > THRESHOLD_LIGHT_BRIGHT + THRESHOLD_LIGHT_HYST) next = LIGHT_BRIGHT;
        else                                                             next = LIGHT_NORMAL;
    }
    if (current == LIGHT_UNKNOWN) next = LIGHT_NORMAL;

    basira.light.state    = next;
    basira.light.lastDiff = diff;
}

// ============================================================
//  Sensor: Heart — RR bounds check prevents HRV inflation
// ============================================================
void updateRRBuffer(uint16_t rr)
{
    rrHistory[rrIndex] = rr;
    rrIndex = (rrIndex + 1) % RR_BUF;
    if (rrSamples < RR_BUF) rrSamples++;
}

void clearHeartBuffer()
{
    memset(rrHistory, 0, sizeof(rrHistory));
    rrIndex = 0; rrSamples = 0;
}

void readHeartSensor()
{
    basira.heart.ir = max30102.getIR();

    if (basira.heart.ir < IR_ON_SKIN_THRESHOLD)
    {
        basira.heart.skin         = OFF_SKIN;
        basira.heart.bpm          = 0.0f;
        basira.heart.averageBPM   = 0.0f;
        basira.heart.rr           = 0;
        basira.heart.hrv          = 0.0f;
        basira.heart.beatDetected = false;
        clearHeartBuffer();
        return;
    }
    basira.heart.skin = ON_SKIN;

    if (checkForBeat(basira.heart.ir))
    {
        static uint32_t lastBeat = 0;
        uint32_t now = millis();
        if (lastBeat != 0)
        {
            uint32_t rr = now - lastBeat;
            if (rr >= RR_MIN_MS && rr <= RR_MAX_MS)
            {
                basira.heart.rr = (uint16_t)rr;
                updateRRBuffer((uint16_t)rr);
                float bpm = 60000.0f / rr;
                basira.heart.bpm = bpm;
                basira.heart.averageBPM = (basira.heart.averageBPM < 1.0f)
                    ? bpm : 0.90f * basira.heart.averageBPM + 0.10f * bpm;
            }
        }
        lastBeat              = now;
        basira.heart.beatDetected = true;
    }
    else
    {
        basira.heart.beatDetected = false;
    }
}

// ============================================================
//  Feature: Blink rate window (30s)
//
//  FIX-1: Edge detection REMOVED from here — it lives in
//  readBlinkSensor() now. This function only handles the
//  30-second rate calculation and PERCLOS window reset.
// ============================================================
void calculateBlinkFeatures()
{
    uint32_t now = millis();

    // Live PERCLOS: recalculate every second from partial window
    uint32_t windowElapsed = now - basira.blink.percloseWindowStart;
    if (windowElapsed > 0)
    {
        float live = 100.0f * (float)basira.blink.closedMsInWindow / (float)windowElapsed;
        basira.blink.perclos = constrain(live, 0.0f, 100.0f);
    }

    // Full 60s window expiry: reset accumulator
    if (windowElapsed >= PERCLOS_WINDOW_MS)
    {
        basira.blink.closedMsInWindow    = 0;
        basira.blink.percloseWindowStart = now;
    }

    // 30s blink rate window
    uint32_t blinkElapsed = now - blinkWindowStart;
    if (blinkElapsed >= 30000UL)
    {
        float minutes = blinkElapsed / 60000.0f;
        basira.blink.blinkRate   = (minutes > 0.0f)
            ? (float)basira.blink.blinkCount / minutes : 0.0f;
        basira.blink.blinkCount  = 0;
        basira.blink.windowReady = true;
        blinkWindowStart         = now;
    }
}

// ============================================================
//  Feature: HRV
// ============================================================
void calculateHRV()
{
    if (rrSamples < 5) return;
    float sum = 0.0f;
    for (uint8_t i = 1; i < rrSamples; i++)
        sum += abs((int)rrHistory[i] - (int)rrHistory[i - 1]);
    basira.heart.hrv = sum / (rrSamples - 1);
}

void extractFeatures()
{
    calculateBlinkFeatures();
    calculateHRV();
}

// ============================================================
//  Physiology evaluation
// ============================================================
void evaluateBlinkStatus()
{
    if (!basira.blink.windowReady) { basira.physiology.blink = BLINK_UNKNOWN; return; }
    if      (basira.blink.blinkRate >= 12) basira.physiology.blink = BLINK_NORMAL;
    else if (basira.blink.blinkRate >= 8)  basira.physiology.blink = BLINK_LOW;
    else                                   basira.physiology.blink = BLINK_VERY_LOW;
}

void evaluateHeartStatus()
{
    if (basira.heart.skin == OFF_SKIN) { basira.physiology.heart = HEART_UNKNOWN; return; }
    basira.physiology.heart = (basira.heart.averageBPM > THRESHOLD_HEART_HIGH)
        ? HEART_HIGH : HEART_NORMAL;
}

void evaluateHRVStatus()
{
    if (basira.heart.skin == OFF_SKIN || rrSamples < 5)
    { basira.physiology.hrv = HRV_UNKNOWN; return; }
    basira.physiology.hrv = (basira.heart.hrv < THRESHOLD_HRV_LOW)
        ? HRV_LOW : HRV_NORMAL;
}

void evaluateGSRStatus()
{
    if (!basira.gsr.onSkin) { basira.physiology.gsr = GSR_UNKNOWN; return; }
    basira.physiology.gsr = (basira.gsr.delta < THRESHOLD_GSR_ELEVATED)
        ? GSR_ELEVATED : GSR_NORMAL;
}

void evaluatePhysiology()
{
    evaluateBlinkStatus();
    evaluateHeartStatus();
    evaluateHRVStatus();
    evaluateGSRStatus();
}

// ============================================================
//  Decision engine
// ============================================================
void updateDecisionEngine()
{
    basira.decision.vibration = false;
    basira.decision.riskScore = 0;

    if (basira.heart.skin == OFF_SKIN)
    {
        basira.decision.state = SYSTEM_MONITORING;
        return;
    }

    // Severe visual fatigue
    if (basira.blink.perclos >= 40.0f)
    {
        basira.decision.state = SYSTEM_VISUAL_FATIGUE;
        basira.decision.vibration = true;
        basira.decision.riskScore = 3;
        return;
    }

    // Physiological stress
    if (basira.physiology.hrv == HRV_LOW &&
        basira.physiology.gsr == GSR_ELEVATED)
    {
        basira.decision.state = SYSTEM_HIGH_STRESS;
        basira.decision.vibration = true;
        basira.decision.riskScore = 2;
        return;
    }

    // Mild fatigue
    if (basira.blink.perclos >= 20.0f)
    {
        basira.decision.state = SYSTEM_MILD_FATIGUE;
        basira.decision.riskScore = 1;
        return;
    }

    basira.decision.state = SYSTEM_HEALTHY;
}

// ============================================================
//  Motor (non-blocking)
// ============================================================
void updateMotor()
{
    if (basira.decision.vibration && !motorRunning)
    {
        digitalWrite(PIN_MOTOR, HIGH);
        motorRunning   = true;
        motorStartTime = millis();
    }
    if (motorRunning && millis() - motorStartTime >= MOTOR_PULSE_MS)
    {
        digitalWrite(PIN_MOTOR, LOW);
        motorRunning              = false;
        basira.decision.vibration = false;
    }
}

// ============================================================
//  Protocol enum mapping
// ============================================================
uint8_t mapState(SystemState s)
{
    switch (s)
    {
        case SYSTEM_STARTUP:        return BSTATE_STARTUP;
        case SYSTEM_CALIBRATION:    return BSTATE_CALIBRATION;
        case SYSTEM_MONITORING:     return BSTATE_MONITORING;
        case SYSTEM_HEALTHY:        return BSTATE_HEALTHY;
        case SYSTEM_MILD_FATIGUE:   return BSTATE_MILD_FATIGUE;
        case SYSTEM_VISUAL_FATIGUE: return BSTATE_VISUAL_FATIGUE;
        case SYSTEM_HIGH_STRESS:    return BSTATE_HIGH_STRESS;
        default:                    return BSTATE_STARTUP;
    }
}

uint8_t mapLight(LightState s)
{
    switch (s)
    {
        case LIGHT_DARK:   return BLIGHT_DARK;
        case LIGHT_BRIGHT: return BLIGHT_BRIGHT;
        case LIGHT_NORMAL: return BLIGHT_NORMAL;
        default:           return BLIGHT_UNKNOWN;
    }
}

// ============================================================
//  BLE packet send
// ============================================================
void sendBlePacket()
{
    if (!bleConnected) return;

    BasiraPacket pkt;
    pkt.seq             = packetSeq++;
    pkt.heartRateBpm    = basira.heart.averageBPM;
    pkt.blinkRatePerMin = basira.blink.windowReady ? basira.blink.blinkRate : 0.0f;
    pkt.hrv             = basira.heart.hrv;
    pkt.perclos         = basira.blink.perclos;
    pkt.gsrFiltered     = (int16_t)basira.gsr.filtered;
    pkt.gsrDelta        = basira.gsr.onSkin ? (int16_t)basira.gsr.delta : 0;
    pkt.lightState      = mapLight(basira.light.state);
    pkt.systemState     = mapState(basira.decision.state);
    pkt.onSkin          = (basira.heart.skin == ON_SKIN) ? 1 : 0;
    pkt.vibrating       = basira.decision.vibration ? 1 : 0;

    bleDataChar->setValue((uint8_t*)&pkt, sizeof(BasiraPacket));
    bleDataChar->notify();
}

