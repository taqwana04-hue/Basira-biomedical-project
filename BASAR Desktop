// ============================================================
//  Dashboard update
// ============================================================
void updateDashboard()
{
    bool stateChanged     = (currentState != lastDrawnState);
    bool connectedChanged = (connected    != lastDrawnConnected);

    if (stateChanged || connectedChanged)
    {
        bool animate       = stateChanged && lastDrawnState != STATE_BOOT;
        lastDrawnState     = currentState;
        lastDrawnConnected = connected;
        drawLayout(animate);
        return;
    }

    if (millis() - lastVitalMs >= 500)
    {
        lastVitalMs = millis();
        drawVitals();
        drawMessage();
    }
}

// ============================================================
//  Protocol mapping
// ============================================================
SystemState mapState(uint8_t s)
{
    switch (s)
    {
        case BSTATE_HEALTHY:        return STATE_HEALTHY;
        case BSTATE_MONITORING:     return STATE_MONITORING;
        case BSTATE_MILD_FATIGUE:   return STATE_MILD_FATIGUE;
        case BSTATE_VISUAL_FATIGUE: return STATE_VISUAL_FATIGUE;
        case BSTATE_HIGH_STRESS:    return STATE_HIGH_STRESS;
        default:                    return STATE_WAITING;
    }
}

// ============================================================
//  BLE notify callback
// ============================================================
void onPacketNotify(BLERemoteCharacteristic*, uint8_t* data,
                    size_t length, bool)
{
    if (length != sizeof(BasiraPacket)) return;

    BasiraPacket pkt;
    memcpy(&pkt, data, sizeof(BasiraPacket));

    heartRate    = pkt.heartRateBpm;
    blinkRate    = pkt.blinkRatePerMin;
    hrv          = pkt.hrv;
    perclos      = pkt.perclos;
    gsrFiltered  = (int)pkt.gsrFiltered;
    gsrDelta     = (int)pkt.gsrDelta;
    gsrOnSkin    = (pkt.gsrFiltered < 3900);
    lightCode    = (pkt.lightState == BLIGHT_DARK) ? 0
                 : (pkt.lightState == BLIGHT_BRIGHT) ? 2 : 1;
    currentState = mapState(pkt.systemState);
    connected    = true;
    lastPacketMs = millis();
}

// ============================================================
//  BLE scan callback
// ============================================================
class BasiraAdvertisedDeviceCallbacks : public BLEAdvertisedDeviceCallbacks
{
    void onResult(BLEAdvertisedDevice dev) override
    {
        Serial.print("[SCAN] ");
        Serial.print(dev.getName().c_str());
        Serial.print("  RSSI=");
        Serial.print(dev.getRSSI());
        Serial.print("  svcUUID=");
        Serial.println(dev.haveServiceUUID()
            ? dev.getServiceUUID().toString().c_str()
            : "(none)");

        if (!dev.haveServiceUUID()) return;
        if (!dev.isAdvertisingService(BLEUUID(BASIRA_SERVICE_UUID))) return;

        dev.getScan()->stop();
        if (targetDevice) { delete targetDevice; targetDevice = nullptr; }
        targetDevice     = new BLEAdvertisedDevice(dev);
        bleDeviceFound   = true;
        bleShouldConnect = true;
        Serial.println("[SCAN] BASIRA found — attempting connection");
    }
};

// ============================================================
//  BLE client callbacks
//
//  FIX-E: onDisconnect() no longer calls bleScan->start() directly.
//  Calling BLE scan functions from inside a BLE stack callback
//  (which runs on core 0) causes a race condition that silently
//  kills the scan. bleNeedsRescan flag is set here and handled
//  safely from loop() on core 1.
// ============================================================
class BasiraClientCallbacks : public BLEClientCallbacks
{
    void onConnect(BLEClient*) override {}

    void onDisconnect(BLEClient*) override
    {
        connected      = false;
        currentState   = STATE_WAITING;
        bleDataChar    = nullptr;
        bleNeedsRescan = true;   // FIX-E: flag only — no scan call here
        Serial.println("[BLE] Disconnected — will rescan from loop()");
    }
};

// ============================================================
//  Connect routine
//
//  FIX-E: bleClient deleted and recreated each attempt to
//  prevent handle leaks across reconnection cycles.
// ============================================================
bool connectToServer()
{
    // FIX-E: clean up previous client before creating a new one
    if (bleClient != nullptr)
    {
        if (bleClient->isConnected())
            bleClient->disconnect();
        delete bleClient;
        bleClient = nullptr;
    }

    bleClient = BLEDevice::createClient();
    bleClient->setClientCallbacks(new BasiraClientCallbacks());

    Serial.println("[BLE] Connecting...");
    if (!bleClient->connect(targetDevice))
    {
        Serial.println("[BLE] connect() failed");
        return false;
    }

    bleClient->setMTU(185);


    BLERemoteService* svc = bleClient->getService(BASIRA_SERVICE_UUID);
    if (!svc)
    {
        Serial.println("[BLE] Service not found on remote");
        bleClient->disconnect();
        return false;
    }

    bleDataChar = svc->getCharacteristic(BASIRA_CHAR_DATA_UUID);
    if (!bleDataChar)
    {
        Serial.println("[BLE] Characteristic not found");
        bleClient->disconnect();
        return false;
    }

    if (bleDataChar->canNotify())
{
    bleDataChar->registerForNotify(onPacketNotify);
    // كتابة صريحة لـ CCCD descriptor لتفعيل الـ notify
    uint8_t notifyOn[] = {0x01, 0x00};
    BLERemoteDescriptor* desc = bleDataChar->getDescriptor(BLEUUID((uint16_t)0x2902));
    if (desc)
        desc->writeValue(notifyOn, 2, true);
    Serial.println("[BLE] Notify subscription confirmed");
}

    connected    = true;
    lastPacketMs = millis();
    Serial.println("[BLE] Connected and subscribed");
    return true;
}

void initializeBLE()
{
    BLEDevice::init("");
    bleScan = BLEDevice::getScan();
    bleScan->setAdvertisedDeviceCallbacks(new BasiraAdvertisedDeviceCallbacks());
    bleScan->setInterval(100);
    bleScan->setWindow(99);
    bleScan->setActiveScan(true);
    bleScan->start(BLE_RECONNECT_SCAN_MS, false);
    Serial.println("[BLE] Scanning...");
}

// ============================================================
//  BLE service loop
//
//  FIX-E: bleNeedsRescan handled here (safe context: loop/core 1).
//  bleScan->clearResults() called before every restart to flush
//  stale scan entries from previous sessions.
// ============================================================
void serviceBLEConnection()
{
    // FIX-E: handle rescan flag set by onDisconnect callback
    if (bleNeedsRescan)
    {
        bleNeedsRescan   = false;
        bleDeviceFound   = false;
        bleShouldConnect = false;
        delay(500);
        Serial.println("[BLE] Restarting scan after disconnect");
        bleScan->clearResults();
        bleScan->start(BLE_RECONNECT_SCAN_MS, false);
    }

    if (bleShouldConnect)
    {
        bleShouldConnect = false;
        if (!connectToServer())
        {
            // connection attempt failed — restart scan
            delay(500);
            Serial.println("[BLE] Connection failed — restarting scan");
            bleScan->clearResults();
            bleScan->start(BLE_RECONNECT_SCAN_MS, false);
        }
    }

    // Watchdog: no packet received within timeout window
    if (connected && millis() - lastPacketMs > BLE_LINK_TIMEOUT_MS)
    {
        Serial.println("[BLE] Link timeout — disconnecting");
        connected    = false;
        currentState = STATE_WAITING;
        if (bleClient && bleClient->isConnected())
        {
            bleClient->disconnect();
            // onDisconnect callback will set bleNeedsRescan = true
        }
        else
        {
            // client already gone — trigger rescan directly
            bleNeedsRescan = true;
        }
    }
}

// ============================================================
//  Setup
// ============================================================
void setup()
