/*************************************************************
               DASHBOARD UPDATE
*************************************************************/

void updateDashboard()
{
    bool stateChanged     = (currentState != lastDrawnState);
    bool connectedChanged = (connected    != lastDrawnConnected);

    if (stateChanged || connectedChanged)
    {
        lastDrawnState     = currentState;
        lastDrawnConnected = connected;
        drawLayout();
        return;
    }

    if (millis() - lastVitalMs >= 500)
    {
        lastVitalMs = millis();
        drawVitals();
    }
}

/*************************************************************
              BLE → DASHBOARD STATE MAPPING
*************************************************************/

SystemState mapProtocolState(uint8_t s)
{
    switch (s)
    {
        case BSTATE_HEALTHY:        return STATE_HEALTHY;
        case BSTATE_MONITORING:     return STATE_MONITORING;
        case BSTATE_MILD_FATIGUE:   return STATE_MILD_FATIGUE;
        case BSTATE_VISUAL_FATIGUE: return STATE_VISUAL_FATIGUE;
        case BSTATE_HIGH_STRESS:    return STATE_HIGH_STRESS;
        // STARTUP / CALIBRATION on the glasses side both show as "waiting" here —
        // intentional: the desktop has nothing useful to plot yet during either.
        default:                    return STATE_WAITING;
    }
}

int mapProtocolLight(uint8_t l)
{
    switch (l)
    {
        case BLIGHT_DARK:   return 0;
        case BLIGHT_BRIGHT: return 2;
        default:             return 1; // NORMAL and UNKNOWN both display as NORMAL
    }
}

/*************************************************************
         BLE NOTIFY CALLBACK — fires on every packet
*************************************************************/

void onPacketNotify(BLERemoteCharacteristic* characteristic,
                     uint8_t* data, size_t length, bool isNotify)
{
    if (length != sizeof(BasiraPacket))
    {
        // Defensive: a malformed/short packet must never be cast onto the struct —
        // doing so would read past the buffer or misinterpret bytes as the wrong
        // field. Drop it and wait for the next one instead.
        return;
    }

    BasiraPacket packet;
    memcpy(&packet, data, sizeof(BasiraPacket));

    heartRate    = packet.heartRateBpm;
    blinkRate    = packet.blinkRatePerMin;
    hrv          = packet.hrv;
    gsrRaw       = packet.gsrFiltered;
    lightCode    = mapProtocolLight(packet.lightState);
    currentState = mapProtocolState(packet.systemState);

    connected    = true;
    lastPacketMs = millis();
}

/*************************************************************
         BLE SCAN CALLBACK — looks for "BASIRA"
*************************************************************/

class BasiraAdvertisedDeviceCallbacks : public BLEAdvertisedDeviceCallbacks
{
    void onResult(BLEAdvertisedDevice advertisedDevice) override
    {
        if (!advertisedDevice.haveServiceUUID()) return;
        if (!advertisedDevice.isAdvertisingService(BLEUUID(BASIRA_SERVICE_UUID))) return;

        advertisedDevice.getScan()->stop();

        if (targetDevice != nullptr) { delete targetDevice; targetDevice = nullptr; }
        targetDevice = new BLEAdvertisedDevice(advertisedDevice);

        bleDeviceFound   = true;
        bleShouldConnect = true;
    }
};

/*************************************************************
         BLE CLIENT CONNECT CALLBACK — tracks link drop
*************************************************************/

class BasiraClientCallbacks : public BLEClientCallbacks
{
    void onConnect(BLEClient* client) override
    {
        // Handled after connect() returns in connectToServer(); nothing needed here.
    }

    void onDisconnect(BLEClient* client) override
    {
        connected = false;
        currentState = STATE_WAITING;
        bleDataChar = nullptr;
        // Resume scanning so the desktop reconnects automatically once the
        // glasses are back in range — no manual reset required.
        bleScan->start(BLE_RECONNECT_SCAN_MS, false);
    }
};

/*************************************************************
         BLE CONNECT ROUTINE
*************************************************************/

bool connectToServer()
{
    bleClient = BLEDevice::createClient();
    bleClient->setClientCallbacks(new BasiraClientCallbacks());

    if (!bleClient->connect(targetDevice))
    {
        return false;
    }

    BLERemoteService* remoteService = bleClient->getService(BASIRA_SERVICE_UUID);
    if (remoteService == nullptr)
    {
        bleClient->disconnect();
        return false;
    }

    bleDataChar = remoteService->getCharacteristic(BASIRA_CHAR_DATA_UUID);
    if (bleDataChar == nullptr)
    {
        bleClient->disconnect();
        return false;
    }

    if (bleDataChar->canNotify())
    {
        bleDataChar->registerForNotify(onPacketNotify);
    }

    connected    = true;
    lastPacketMs = millis();
    return true;
}

void initializeBLE()
{
    BLEDevice::init("");

    bleScan = BLEDevice::getScan();
    bleScan->setAdvertisedDeviceCallbacks(new BasiraAdvertisedDeviceCallbacks());
    bleScan->setInterval(100);
    bleScan->setWindow(99);
    bleScan->setActiveScan(true);
    bleScan->start(BLE_RECONNECT_SCAN_MS, false);
}

void serviceBLEConnection()
{
    if (bleShouldConnect)
    {
        bleShouldConnect = false;
        if (!connectToServer())
        {
            // Connection attempt failed — go back to scanning rather than
            // getting stuck. Common causes: glasses rebooted mid-handshake,
            // or another central briefly grabbed the slot first.
            bleScan->start(BLE_RECONNECT_SCAN_MS, false);
        }
    }

    // Link-loss watchdog: if no packet has arrived recently even though we
    // think we're connected, treat it as dead. BLE disconnect callbacks are
    // usually reliable, but a stalled link without a clean disconnect event
    // is possible (e.g. the glasses lost power abruptly) — this catches that.
    if (connected && (millis() - lastPacketMs > BLE_LINK_TIMEOUT_MS))
    {
        connected    = false;
        currentState = STATE_WAITING;
        if (bleClient != nullptr && bleClient->isConnected())
        {
            bleClient->disconnect(); // triggers onDisconnect → resumes scanning
        }
        else
        {
            bleScan->start(BLE_RECONNECT_SCAN_MS, false);
        }
    }
}

/*************************************************************
                       SETUP
*************************************************************/

void setup()
{
    Serial.begin(115200);

    tft.init();
    tft.setRotation(0);
    tft.fillScreen(BG_COLOR);
    tft.setTextWrap(false);

    splashScreen();

    currentState = STATE_WAITING;
    connected    = false;

    drawLayout();

    initializeBLE();
}

/*************************************************************
                        LOOP
*************************************************************/

void loop()
{
    serviceBLEConnection();
    updateDashboard();
    animateBlink();
}
