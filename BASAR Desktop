/**********************************************************************
 *
 *  BasarAssistant.ino  —  Firmware v3.3.0
 *  BASAR Desktop Assistant — ESP32 DevKit v1 + ILI9488 3.5" TFT
 *
 *  Wiring (unchanged from v2/v3.0):
 *    CS → GPIO5,  RESET → GPIO4,  DC → GPIO2
 *    MOSI → GPIO23,  SCK → GPIO18,  MISO → GPIO19
 *    LED/VCC → 3.3V,  GND → GND
 *
 *  Fixes in v3.3 (over v3.2):
 *
 *  FIX-E  BLE drops after ~30s and never reconnects:
 *    Root cause: BasiraClientCallbacks::onDisconnect() was calling
 *    bleScan->start() directly inside the BLE stack callback.
 *    The BLE stack runs on core 0; calling scan functions from within
 *    a stack callback causes a race condition that silently kills the
 *    scan — the device appears to restart scanning but never finds
 *    BASIRA again.
 *
 *    Fix: onDisconnect() now only sets bleNeedsRescan = true.
 *    The actual bleScan->start() call happens in serviceBLEConnection()
 *    which runs from loop() on core 1 — the correct safe context.
 *    bleScan->clearResults() added before every restart to flush stale
 *    entries. bleClient is deleted and recreated on each connection
 *    attempt to prevent handle leaks.
 *
 *  All v3.2 fixes preserved:
 *    - FIX-D: BLE_LINK_TIMEOUT_MS = 15000ms
 *    - FIX-1: BLE watchdog anchored to connectToServer() return time
 *    - FIX-2: FACE_X/FACE_Y corrected for landscape 480x320 geometry
 *    - FIX-3: GSR card shows NO PROBE / ELEVATED / NORMAL correctly
 *    - FIX-4: PERCLOS card display
 *    - FIX-5: 500ms delay before BLE scan restart on disconnect
 *
 *********************************************************************/

#include <SPI.h>
#include <TFT_eSPI.h>
#include <BLEDevice.h>
#include <BLEUtils.h>
#include <BLEScan.h>
#include <BLEAdvertisedDevice.h>
#include <BLEClient.h>
#include "BasiraProtocol_1.h"

TFT_eSPI tft = TFT_eSPI();

// ============================================================
//  Screen dimensions — landscape (rotation 1)
// ============================================================
#define SCREEN_W  480
#define SCREEN_H  320

// ============================================================
//  Colors
// ============================================================
#define BG_COLOR             TFT_BLACK
#define DARK_BLUE            0x08D4
#define PANEL_COLOR          0x18C3
#define CARD_COLOR           0x1082
#define BASAR_BLUE           0x1D9F
#define COLOR_GRAY           0x8410

#define COLOR_HEALTHY        0x07E0
#define COLOR_MONITORING     0xFFE0
#define COLOR_MILD_FATIGUE   0xFD20
#define COLOR_VISUAL_FATIGUE 0xF800
#define COLOR_HIGH_STRESS    0xF81F
#define COLOR_WAITING        0x8410

// ============================================================
//  Layout constants — landscape 480x320
// ============================================================
#define HEADER_H     44
#define FOOTER_H     28
#define FOOTER_Y     (SCREEN_H - FOOTER_H)

#define FACE_X       150
#define FACE_Y       168
#define FACE_R        68

#define VITALS_X     300
#define VITALS_Y     (HEADER_H + 6)
#define CARD_W       168
#define CARD_H        46

#define MSG_X        8
#define MSG_Y        (FOOTER_Y - 56)
#define MSG_W        (VITALS_X - 16)
#define MSG_H        46

// ============================================================
//  Timing
// ============================================================
#define BLINK_INTERVAL_MS      4500
#define BLINK_HOLD_MS          120
#define BLE_LINK_TIMEOUT_MS    30000
#define BLE_RECONNECT_SCAN_MS  4000

// ============================================================
//  States
// ============================================================
enum SystemState
{
    STATE_BOOT, STATE_WAITING,
    STATE_HEALTHY, STATE_MONITORING,
    STATE_MILD_FATIGUE, STATE_VISUAL_FATIGUE, STATE_HIGH_STRESS
};

// ============================================================
//  Sensor data (decoded from BLE packet)
// ============================================================
float       heartRate    = 0.0f;
float       blinkRate    = 0.0f;
float       hrv          = 0.0f;
float       perclos      = 0.0f;
int         gsrFiltered  = 0;
int         gsrDelta     = 0;
bool        gsrOnSkin    = false;
int         lightCode    = 1;
SystemState currentState = STATE_WAITING;
bool        connected    = false;

// ============================================================
//  Animation state
// ============================================================
SystemState lastDrawnState     = STATE_BOOT;
bool        lastDrawnConnected = false;

unsigned long lastBlinkMs  = 0;
unsigned long lastVitalMs  = 0;
unsigned long lastPacketMs = 0;

// ============================================================
//  BLE client state
// ============================================================
BLEScan*    bleScan      = nullptr;
BLEClient*  bleClient    = nullptr;
BLERemoteCharacteristic* bleDataChar = nullptr;

bool                 bleDeviceFound   = false;
bool                 bleShouldConnect = false;
bool                 bleNeedsRescan   = false;   // FIX-E: flag set by callback, handled in loop()
BLEAdvertisedDevice* targetDevice     = nullptr;

// ============================================================
//  State → color / message
// ============================================================
uint16_t stateColor(SystemState s)
{
    switch (s)
    {
        case STATE_HEALTHY:        return COLOR_HEALTHY;
        case STATE_MONITORING:     return COLOR_MONITORING;
        case STATE_MILD_FATIGUE:   return COLOR_MILD_FATIGUE;
        case STATE_VISUAL_FATIGUE: return COLOR_VISUAL_FATIGUE;
        case STATE_HIGH_STRESS:    return COLOR_HIGH_STRESS;
        default:                   return COLOR_WAITING;
    }
}

const char* stateMessage(SystemState s)
{
    switch (s)
    {
        case STATE_HEALTHY:        return "You're doing great!";
        case STATE_MONITORING:     return "Monitoring...";
        case STATE_MILD_FATIGUE:   return "Take a short break";
        case STATE_VISUAL_FATIGUE: return "Rest your eyes";
        case STATE_HIGH_STRESS:    return "You seem stressed";
        default:                   return "Waiting for BASIRA";
    }
}

// ============================================================
//  Face engine
// ============================================================
void drawHead(uint16_t color)
{
    tft.fillCircle(FACE_X, FACE_Y, FACE_R, color);
    tft.drawCircle(FACE_X, FACE_Y, FACE_R, TFT_WHITE);
}

void drawEyesHappy()
{
    tft.fillCircle(FACE_X - 26, FACE_Y - 18, 9, TFT_BLACK);
    tft.fillCircle(FACE_X + 26, FACE_Y - 18, 9, TFT_BLACK);
    tft.fillCircle(FACE_X - 23, FACE_Y - 21, 3, TFT_WHITE);
    tft.fillCircle(FACE_X + 29, FACE_Y - 21, 3, TFT_WHITE);
    tft.drawLine(FACE_X - 36, FACE_Y - 34, FACE_X - 16, FACE_Y - 30, TFT_BLACK);
    tft.drawLine(FACE_X + 16, FACE_Y - 30, FACE_X + 36, FACE_Y - 34, TFT_BLACK);
}

void drawEyesNormal()
{
    tft.fillCircle(FACE_X - 26, FACE_Y - 18, 7, TFT_BLACK);
    tft.fillCircle(FACE_X + 26, FACE_Y - 18, 7, TFT_BLACK);
}

void drawEyesSleepy()
{
    tft.fillCircle(FACE_X - 26, FACE_Y - 18, 7, TFT_BLACK);
    tft.fillCircle(FACE_X + 26, FACE_Y - 18, 7, TFT_BLACK);
    uint16_t lid = COLOR_VISUAL_FATIGUE;
    for (int i = 0; i < 6; i++)
    {
        tft.drawFastHLine(FACE_X - 34, FACE_Y - 22 + i, 17, lid);
        tft.drawFastHLine(FACE_X + 18, FACE_Y - 22 + i, 17, lid);
    }
    tft.drawLine(FACE_X - 36, FACE_Y - 30, FACE_X - 16, FACE_Y - 34, TFT_BLACK);
    tft.drawLine(FACE_X + 16, FACE_Y - 34, FACE_X + 36, FACE_Y - 30, TFT_BLACK);
}

void drawEyesStress()
{
    tft.fillCircle(FACE_X - 26, FACE_Y - 18, 8, TFT_BLACK);
    tft.fillCircle(FACE_X + 26, FACE_Y - 18, 8, TFT_BLACK);
    for (int d = 0; d <= 1; d++)
    {
        tft.drawLine(FACE_X - 38, FACE_Y - 33 + d, FACE_X - 16, FACE_Y - 27 + d, TFT_BLACK);
        tft.drawLine(FACE_X + 16, FACE_Y - 27 + d, FACE_X + 38, FACE_Y - 33 + d, TFT_BLACK);
    }
}

void drawEyesWaiting()
{
    tft.drawCircle(FACE_X - 26, FACE_Y - 18, 8, TFT_BLACK);
    tft.drawCircle(FACE_X + 26, FACE_Y - 18, 8, TFT_BLACK);
}

void drawEyesClosed(uint16_t faceColor)
{
    tft.fillCircle(FACE_X - 26, FACE_Y - 18, 10, faceColor);
    tft.fillCircle(FACE_X + 26, FACE_Y - 18, 10, faceColor);
    tft.drawFastHLine(FACE_X - 34, FACE_Y - 18, 17, TFT_BLACK);
    tft.drawFastHLine(FACE_X + 17, FACE_Y - 18, 17, TFT_BLACK);
}

void drawSmile()
{
    tft.drawArc(FACE_X, FACE_Y + 20, 28, 22, 20, 160, TFT_BLACK, BG_COLOR);
}

void drawNeutral()
{
    tft.drawFastHLine(FACE_X - 18, FACE_Y + 26, 36, TFT_BLACK);
    tft.drawFastHLine(FACE_X - 18, FACE_Y + 27, 36, TFT_BLACK);
}

void drawSad()
{
    tft.drawArc(FACE_X, FACE_Y + 46, 26, 21, 200, 340, TFT_BLACK, BG_COLOR);
}

void drawWorried()
{
    tft.drawArc(FACE_X, FACE_Y + 40, 20, 15, 210, 330, TFT_BLACK, BG_COLOR);
}

void drawStressMouth()
{
    for (int i = -18; i < 18; i += 6)
    {
        int y1 = (((i / 6) & 1) == 0) ? FACE_Y + 26 : FACE_Y + 31;
        int y2 = (((i / 6) & 1) == 0) ? FACE_Y + 31 : FACE_Y + 26;
        tft.drawLine(FACE_X + i, y1, FACE_X + i + 6, y2, TFT_BLACK);
    }
}

void wipeFaceArea(uint16_t newColor)
{
    for (int r = 0; r <= FACE_R + 2; r += 6)
        tft.fillCircle(FACE_X, FACE_Y, r, newColor);
    tft.drawCircle(FACE_X, FACE_Y, FACE_R, TFT_WHITE);
}

void drawFace(SystemState s, bool animate = false)
{
    uint16_t color = stateColor(s);
    if (animate)
        wipeFaceArea(color);
    else
        drawHead(color);

    switch (s)
    {
        case STATE_HEALTHY:
            drawEyesHappy();  drawSmile();        break;
        case STATE_MONITORING:
            drawEyesNormal(); drawNeutral();       break;
        case STATE_MILD_FATIGUE:
            drawEyesNormal(); drawSad();           break;
        case STATE_VISUAL_FATIGUE:
            drawEyesSleepy(); drawWorried();       break;
        case STATE_HIGH_STRESS:
            drawEyesStress(); drawStressMouth();   break;
        default:
            drawEyesWaiting(); drawNeutral();      break;
    }
}

void animateBlink()
{
    if (millis() - lastBlinkMs < BLINK_INTERVAL_MS) return;
    lastBlinkMs = millis();
    drawEyesClosed(stateColor(currentState));
    delay(BLINK_HOLD_MS);
    drawFace(currentState);
}

// ============================================================
//  UI components
// ============================================================
void drawPanel(int x, int y, int w, int h, uint16_t color)
{
    tft.fillRoundRect(x, y, w, h, 8, color);
    tft.drawRoundRect(x, y, w, h, 8, TFT_WHITE);
}

void drawHeader()
{
    drawPanel(4, 4, SCREEN_W - 8, HEADER_H - 6, DARK_BLUE);
    tft.setTextColor(TFT_WHITE, DARK_BLUE);
    tft.setTextSize(2);
    tft.setTextDatum(ML_DATUM);
    tft.drawString("BASAR", 16, 4 + (HEADER_H - 6) / 2);

    tft.fillCircle(SCREEN_W - 20, 4 + (HEADER_H - 6) / 2, 7,
                   connected ? TFT_GREEN : TFT_RED);
    tft.drawCircle(SCREEN_W - 20, 4 + (HEADER_H - 6) / 2, 7, TFT_WHITE);
    tft.setTextSize(1);
    tft.setTextDatum(MR_DATUM);
    tft.drawString(connected ? "Connected" : "Waiting",
                   SCREEN_W - 32, 4 + (HEADER_H - 6) / 2);
}

void drawFooter()
{
    drawPanel(4, FOOTER_Y + 2, SCREEN_W - 8, FOOTER_H - 4, DARK_BLUE);
    tft.setTextColor(TFT_WHITE, DARK_BLUE);
    tft.setTextDatum(MC_DATUM);
    tft.setTextSize(1);
    tft.drawString("BASIRA Smart Glasses  v3.3", SCREEN_W / 2, FOOTER_Y + 2 + (FOOTER_H - 4) / 2);
}

void drawMessage()
{
    uint16_t accent = stateColor(currentState);
    tft.fillRoundRect(MSG_X, MSG_Y, MSG_W, MSG_H, 10, accent);
    tft.fillRoundRect(MSG_X + 2, MSG_Y + 2, MSG_W - 4, MSG_H - 4, 8, PANEL_COLOR);
    tft.drawRoundRect(MSG_X + 2, MSG_Y + 2, MSG_W - 4, MSG_H - 4, 8, accent);
    tft.setTextColor(TFT_WHITE, PANEL_COLOR);
    tft.setTextDatum(MC_DATUM);
    tft.setTextSize(2);
    tft.drawString(stateMessage(currentState),
                   MSG_X + MSG_W / 2, MSG_Y + MSG_H / 2);
    tft.setTextSize(1);
}

void drawCard(int x, int y, const char* title, const String& value, uint16_t accent)
{
    drawPanel(x, y, CARD_W, CARD_H, CARD_COLOR);
    tft.fillRoundRect(x, y, 4, CARD_H, 3, accent);
    tft.setTextColor(0xC618, CARD_COLOR);
    tft.setTextDatum(TL_DATUM);
    tft.setTextSize(1);
    tft.drawString(title, x + 10, y + 6);
    tft.setTextColor(TFT_WHITE, CARD_COLOR);
    tft.drawString(value,  x + 10, y + 24);
}

void drawCardGSR(int x, int y, uint16_t accent)
{
    drawPanel(x, y, CARD_W, CARD_H, CARD_COLOR);
    if (gsrOnSkin)
        tft.fillRoundRect(x, y, 4, CARD_H, 3, accent);
    else
        tft.fillRoundRect(x, y, 4, CARD_H, 3, COLOR_GRAY);

    tft.setTextColor(0xC618, CARD_COLOR);
    tft.setTextDatum(TL_DATUM);
    tft.setTextSize(1);
    tft.drawString("STRESS (GSR)", x + 10, y + 6);

    if (!gsrOnSkin)
    {
        tft.setTextColor(COLOR_GRAY, CARD_COLOR);
        tft.drawString("NO PROBE",  x + 10, y + 24);
    }
    else
    {
        const char* label = (gsrDelta < -20) ? "ELEVATED" : "NORMAL";
        tft.setTextColor(TFT_WHITE, CARD_COLOR);
        tft.drawString(String(label), x + 10, y + 24);
    }
    tft.setTextSize(1);
}

void drawVitals()
{
    uint16_t accent = stateColor(currentState);
    int y   = VITALS_Y;
    int gap = CARD_H + 6;

    drawCard(VITALS_X, y,
             "HEART RATE",
             (heartRate > 1.0f) ? String(heartRate, 1) + " BPM" : "---",
             accent);

    drawCard(VITALS_X, y + gap,
             "BLINK RATE",
             (blinkRate > 0.0f) ? String(blinkRate, 1) + " /min" : "Calibrating",
             accent);

    drawCard(VITALS_X, y + gap * 2,
             "PERCLOS",
             String(perclos, 1) + " %",
             accent);

    drawCardGSR(VITALS_X, y + gap * 3, accent);
}

void drawLayout(bool animateFace = false)
{
    tft.fillScreen(BG_COLOR);
    drawHeader();
    drawFooter();
    drawFace(currentState, animateFace);
    drawMessage();
    drawVitals();
}

