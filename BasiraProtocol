/******************************************************************************************
 *
 *  BasiraProtocol.h  —  v3.3.0
 *  Shared BLE contract between BASIRA glasses (server) and BASAR desktop (client).
 *
 *  COPY THIS EXACT FILE INTO BOTH PROJECT FOLDERS.
 *  Any field-order or type mismatch between the two copies will silently corrupt
 *  every field after the divergent one. The static_assert at the bottom is your
 *  compile-time guard — if it fails, both firmwares must be rebuilt together.
 *
 *  Changelog v3.2:
 *    - No struct changes from v3.1 (still 28 bytes)
 *    - File kept identical to ensure both sides always compile from same source
 *
 *  Changelog v3.1:
 *    - Added float perclos to BasiraPacket (PERCLOS: % eye closure over 1-min window)
 *    - Struct size: 24 → 28 bytes
 *
 ******************************************************************************************/
#pragma once

#define BASIRA_SERVICE_UUID     "6e400001-b5a3-f393-e0a9-e50e24dcca9e"
#define BASIRA_CHAR_DATA_UUID   "6e400002-b5a3-f393-e0a9-e50e24dcca9e"
#define BASIRA_DEVICE_NAME      "BASIRA"

enum BasiraSystemState : uint8_t
{
    BSTATE_STARTUP        = 0,
    BSTATE_CALIBRATION    = 1,
    BSTATE_MONITORING     = 2,
    BSTATE_HEALTHY        = 3,
    BSTATE_MILD_FATIGUE   = 4,
    BSTATE_VISUAL_FATIGUE = 5,
    BSTATE_HIGH_STRESS    = 6
};

enum BasiraLightState : uint8_t
{
    BLIGHT_UNKNOWN = 0,
    BLIGHT_DARK    = 1,
    BLIGHT_NORMAL  = 2,
    BLIGHT_BRIGHT  = 3
};

#pragma pack(push,1)

struct BasiraPacket
{
    uint32_t seq;

    float heartRateBpm;
    float blinkRatePerMin;
    float hrv;
    float perclos;

    int16_t gsrFiltered;
    int16_t gsrDelta;

    uint8_t lightState;
    uint8_t systemState;
    uint8_t onSkin;
    uint8_t vibrating;
};

#pragma pack(pop)

static_assert(sizeof(BasiraPacket) == 28,
              "BasiraPacket size mismatch");
